{
  "name": "sigma-sales-backend",
  "version": "1.0.0",
  "description": "Sigma Digital Nusantara - Sales Import & Transformation System (Backend)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
